{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CUTE ChipyardConfig",
  "description": "ChipyardConfig 是一个完整的 SoC 配置描述。从它生成 CuteConfig.scala 和 cute_config.h。",
  "type": "object",
  "required": ["version", "id", "cute", "soc", "capability"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema 版本，当前固定为 1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "ChipyardConfig 唯一标识，如 cute4tops_scp128。生成的 Scala class 名由此推导。"
    },
    "cute": {
      "type": "object",
      "required": ["config", "instances", "isa"],
      "additionalProperties": false,
      "properties": {
        "config": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9_]*$",
          "description": "CUTE 加速器参数预设 id，引用 configs/cute_configs/<id>.yaml"
        },
        "instances": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "minItems": 1,
          "description": "WithCUTE(Seq(...)) 中挂载 CUTE 的 core id 列表"
        },
        "isa": {
          "type": "object",
          "required": ["version"],
          "additionalProperties": false,
          "properties": {
            "version": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$",
              "description": "指令集版本，引用 configs/cute_isa_versions/<version>.yaml"
            }
          }
        }
      }
    },
    "soc": {
      "type": "object",
      "required": ["core", "bus", "vector"],
      "additionalProperties": false,
      "properties": {
        "core": {
          "type": "object",
          "required": ["kind", "count"],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["rocket", "boom", "shuttle", "mixed"],
              "description": "处理器核心类型"
            },
            "count": {
              "type": "integer",
              "minimum": 1,
              "description": "核心数量"
            },
            "shuttle_tile_beat_bytes": {
              "type": "integer",
              "minimum": 1,
              "description": "WithShuttleTileBeatBytes 参数"
            },
            "clusters": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["kind", "count"],
                "additionalProperties": false,
                "properties": {
                  "kind": { "type": "string", "enum": ["rocket", "boom", "shuttle"] },
                  "count": { "type": "integer", "minimum": 1 },
                  "variant": { "type": "string" }
                }
              },
              "description": "mixed core config 的核心组成，占位字段"
            }
          }
        },
        "bus": {
          "type": "object",
          "required": ["system_bits", "memory_bits"],
          "additionalProperties": false,
          "properties": {
            "system_bits": {
              "type": "integer",
              "minimum": 1,
              "description": "WithSystemBusWidth 参数，bit"
            },
            "memory_bits": {
              "type": "integer",
              "minimum": 1,
              "description": "WithNBitMemoryBus 参数，bit"
            }
          }
        },
        "cache": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "inclusive_kb": { "type": "integer", "minimum": 1 },
            "outer_latency_cycles": { "type": "integer", "minimum": 0 },
            "banks": { "type": "integer", "minimum": 1 },
            "cache_hash": { "type": "boolean" },
            "tl_monitors": { "type": "boolean" }
          }
        },
        "vector": {
          "type": "object",
          "required": ["version"],
          "additionalProperties": false,
          "description": "Chipyard SoC 中的软件可见向量实现版本。无向量实现时显式写 none。",
          "properties": {
            "version": {
              "$ref": "#/definitions/vector_version_id",
              "description": "引用 configs/vector_versions/<version>.yaml"
            }
          }
        }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tensor_ops": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "支持的 tensor 操作列表"
        },
        "layer_ops": {
          "type": "array",
          "items": { "type": "string" }
        },
        "fused_ops": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "trace_capability": {
      "type": "object",
      "additionalProperties": false,
      "description": "RTL trace 能力声明（占位，Phase 3 细化），默认全部 false",
      "properties": {
        "structured_trace": { "type": "boolean" },
        "d_store_data": { "type": "boolean" },
        "mem_req_rsp": { "type": "boolean" },
        "perf_counter_snapshot": { "type": "boolean" }
      }
    }
  },
  "definitions": {
    "vector_version_id": {
      "anyOf": [
        {
          "type": "string",
          "const": "none",
          "description": "无向量实现"
        },
        {
          "type": "string",
          "pattern": "^(?!none$)[a-z][a-z0-9_]*$",
          "description": "向量实现版本 id，如 saturn_rvv"
        }
      ]
    }
  }
}
