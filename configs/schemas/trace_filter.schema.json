{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CUTE Trace Filter",
  "description": "可复用 trace 过滤器的占位 manifest。Phase 0 只冻结过滤器的身份、用途和状态；具体的过滤谓词后置。",
  "type": "object",
  "required": ["version", "name", "purpose", "description", "status"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema 版本，固定为 1。"
    },
    "name": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$",
      "description": "trace 过滤器名称，按约定与文件名 stem 对齐。"
    },
    "purpose": {
      "type": "string",
      "enum": ["func", "perf", "debug"],
      "description": "该过滤器用于功能验证、性能分析还是调试。"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["placeholder", "draft", "stable"]
    }
  }
}
