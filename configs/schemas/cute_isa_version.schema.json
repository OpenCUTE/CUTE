{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CUTE ISA Version",
  "description": "CUTE 内部指令集版本。ChipyardConfig 通过 compatibility.isa.version 引用这里定义的 YGJK/CUTE instruction set。Phase 0 不读取 Scala 或 generated header；后续由 Chipyard exporter facts / header fingerprint 做强一致性检查。Header 产物归属于 ChipyardConfig.export.generated_headers，不在本 manifest 中记录。",
  "type": "object",
  "required": ["version", "id", "source", "groups"],
  "additionalProperties": false,
  "properties": {
    "enums": {
      "type": "object",
      "description": "指令字段中使用的枚举类型定义。codegen 依此生成 C 枚举宏。key 为枚举类型名，与 field 的 enum_ref 对应。",
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_]*$": { "$ref": "#/definitions/enum_def" }
      },
      "additionalProperties": false
    },
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema 版本，当前固定为 1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "ISA version 唯一标识，如 cute_isa_v1"
    },
    "description": {
      "type": "string"
    },
    "source": {
      "type": "object",
      "required": ["scala_file", "scala_objects"],
      "additionalProperties": false,
      "properties": {
        "scala_file": {
          "type": "string",
          "description": "定义指令集 object 的 Scala 源码路径，仅作为 Chipyard exporter metadata；Phase 0 不读取 Scala。"
        },
        "scala_objects": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true,
          "description": "该 ISA version 后续由 Chipyard exporter 对齐的 Scala object 全名。"
        }
      }
    },
    "rocc": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "opcode": {
          "type": "string",
          "pattern": "^0x[0-9A-Fa-f]+$",
          "description": "RoCC opcode，当前来自 ygjk.h / inline asm 约定。"
        },
        "cute_internal_offset": {
          "type": "integer",
          "minimum": 0,
          "description": "CUTE 内部指令在 RoCC funct 空间中的偏移量。"
        }
      }
    },
    "groups": {
      "type": "object",
      "required": ["ygjk", "cute"],
      "additionalProperties": false,
      "properties": {
        "ygjk": { "$ref": "#/definitions/instruction_group" },
        "cute": { "$ref": "#/definitions/instruction_group" }
      }
    }
  },
  "definitions": {
    "instruction_group": {
      "type": "object",
      "required": ["scala_object", "description", "rocc_funct_offset", "instructions"],
      "additionalProperties": false,
      "properties": {
        "scala_object": {
          "type": "string",
          "description": "该 group 对齐的 Scala object。"
        },
        "description": {
          "type": "string",
          "description": "该 instruction group 的用途说明。"
        },
        "rocc_funct_offset": {
          "type": "integer",
          "minimum": 0,
          "description": "从 Scala funct 到 RoCC funct 的固定偏移量。"
        },
        "instructions": {
          "type": "array",
          "items": { "$ref": "#/definitions/instruction" },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "instruction": {
      "type": "object",
      "required": ["name", "funct", "rocc_funct", "description", "return_description"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$",
          "description": "软件 / header 可见的指令名。"
        },
        "funct": {
          "type": "integer",
          "minimum": 0,
          "description": "Scala CuteInstConfig.funct。"
        },
        "rocc_funct": {
          "type": "integer",
          "minimum": 0,
          "description": "CUTE_INST_FUNCT_<name> 在 generated header 中的值。"
        },
        "description": {
          "type": "string",
          "description": "从 Scala CuteInstConfig.description 抄录的指令说明。"
        },
        "return_description": {
          "type": "string",
          "description": "从 Scala CuteInstConfig.returnDescription 抄录的返回值说明。"
        },
        "fields": {
          "type": "object",
          "description": "指令 cfgData1 / cfgData2 中的字段布局。无参数指令不设此字段。",
          "additionalProperties": false,
          "properties": {
            "cfgData1": {
              "type": "array",
              "items": { "$ref": "#/definitions/field" },
              "description": "cfgData1 (rs1) 中的字段列表，按 lo 从小到大排列。"
            },
            "cfgData2": {
              "type": "array",
              "items": { "$ref": "#/definitions/field" },
              "description": "cfgData2 (rs2) 中的字段列表，按 lo 从小到大排列。"
            }
          }
        }
      }
    },
    "field": {
      "type": "object",
      "required": ["name", "hi", "lo"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*$",
          "description": "字段名（与 Scala CuteInstConfig 中的字段名一致）。"
        },
        "hi": {
          "type": "integer",
          "minimum": 0,
          "maximum": 63,
          "description": "字段高位 bit 索引（inclusive）。"
        },
        "lo": {
          "type": "integer",
          "minimum": 0,
          "maximum": 63,
          "description": "字段低位 bit 索引（inclusive）。"
        },
        "description": {
          "type": "string",
          "description": "字段含义说明。"
        },
        "max_value": {
          "type": "integer",
          "minimum": 0,
          "description": "软件填值不应超过此值（(1 << width) - 1 或更小的约束值）。"
        },
        "enum_ref": {
          "type": "string",
          "description": "引用 enums 下定义的枚举类型名。codegens 依此生成 C 枚举宏并校验合法值。"
        }
      }
    },
    "enum_def": {
      "type": "object",
      "required": ["bit_width", "values"],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "description": "枚举类型用途说明。"
        },
        "scala_object": {
          "type": "string",
          "description": "对应 Scala object 全名（仅作参考）。"
        },
        "bit_width": {
          "type": "integer",
          "minimum": 1,
          "description": "枚举值位宽。"
        },
        "values": {
          "type": "array",
          "items": { "$ref": "#/definitions/enum_value" },
          "description": "枚举值列表，按 value 从小到大排列。"
        }
      }
    },
    "enum_value": {
      "type": "object",
      "required": ["name", "value", "description"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*$",
          "description": "枚举成员名（用于生成 C 宏名）。"
        },
        "value": {
          "type": "integer",
          "minimum": 0,
          "description": "枚举数值。"
        },
        "description": {
          "type": "string",
          "description": "枚举成员含义。"
        },
        "a_bits": {
          "type": "integer",
          "minimum": 1,
          "description": "A 操作数位宽（bit）。用于生成 datatype.h 的位宽查询宏。"
        },
        "b_bits": {
          "type": "integer",
          "minimum": 1,
          "description": "B 操作数位宽（bit）。用于生成 datatype.h 的位宽查询宏。"
        },
        "c_bits": {
          "type": "integer",
          "minimum": 1,
          "description": "累加结果位宽（bit）。用于生成 datatype.h 的位宽查询宏。"
        }
      }
    }
  }
}
