{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CUTE ChipyardConfig 参数目录",
  "description": "所有可用参数的字典。人看它选参数写 chipyard_config.yaml，codegen 读它校验和生成。",

  "core_kinds": {
    "shuttle": {
      "description": "Shuttle超标量顺序核心，支持向量扩展（Saturn RVV）和 TCM 紧耦合内存",
      "scala_mixins": ["shuttle.common.WithShuttleTileBeatBytes", "shuttle.common.WithNShuttleCores"],
      "supports_vector": true,
      "supports_tcm": true,
      "params": {
        "shuttle_tile_beat_bytes": {
          "description": "Shuttle tile 每拍传输字节数",
          "type": "integer",
          "default": 64,
          "valid_values": [64]
        }
      }
    },
    "rocket": {
      "description": "Rocket 顺序核心，简单轻量，不支持向量扩展",
      "scala_mixins": ["freechips.rocketchip.rocket.WithNSmallCores"],
      "supports_vector": false,
      "supports_tcm": false,
      "params": {}
    },
    "boom": {
      "description": "BOOM 乱序核心，高性能，不支持向量扩展",
      "scala_mixins": ["boom.v3.common.WithNSmallBooms"],
      "supports_vector": false,
      "supports_tcm": false,
      "params": {}
    }
  },

  "bus": {
    "system_bits": {
      "description": "System Bus 位宽。影响 SoC 内部总线吞吐。",
      "type": "integer",
      "valid_values": [64, 128, 256, 512],
      "scala_mixin": "chipyard.config.WithSystemBusWidth"
    },
    "memory_bits": {
      "description": "Memory Bus 位宽。影响对外访存带宽。",
      "type": "integer",
      "valid_values": [64, 128, 256, 512],
      "scala_mixin": "freechips.rocketchip.subsystem.WithNBitMemoryBus"
    }
  },

  "cache": {
    "inclusive_kb": {
      "description": "L2 inclusive cache 容量（KB）",
      "type": "integer",
      "valid_values": [64, 128, 256, 512, 1024],
      "default": 512
    },
    "outer_latency_cycles": {
      "description": "L2 cache 外部访问延迟周期数。影响 source 数量需求。越小吞吐越高但 source 需求越少。",
      "type": "integer",
      "minimum": 10,
      "maximum": 200,
      "default": 40
    },
    "banks": {
      "description": "Memory bank 数量",
      "type": "integer",
      "valid_values": [2, 4, 8],
      "default": 4,
      "scala_mixin": "freechips.rocketchip.subsystem.WithNBanks"
    },
    "cache_hash": {
      "description": "是否启用 cache 地址 hash，减少 bank 冲突",
      "type": "boolean",
      "default": true,
      "scala_mixin": "freechips.rocketchip.subsystem.WithCacheHash"
    },
    "tl_monitors": {
      "description": "是否启用 TileLink monitors。仿真时关闭可加速。",
      "type": "boolean",
      "default": false,
      "scala_mixin_invert": "freechips.rocketchip.subsystem.WithoutTLMonitors"
    }
  },



  "vector": {
    "saturn_rvv": {
      "description": "Saturn RVV 向量单元，通过 Shuttle tile 集成",
      "scala_mixin": "saturn.shuttle.WithShuttleVectorUnit",
      "params": {
        "vLen": { "description": "向量寄存器位宽", "valid_values": [512], "default": 512 },
        "dLen": { "description": "向量数据通路位宽", "valid_values": [512], "default": 512 },
        "mLen": { "description": "向量 mask 位宽（可选）", "valid_values": [512], "default": 512 }
      }
    },
    "tcm": {
      "description": "Shuttle TCM 紧耦合内存，用于向量数据缓冲",
      "params": {
        "address": { "description": "TCM 基地址", "default": "0x70000000" },
        "size": { "description": "TCM 大小（字节）", "default": 2097152 },
        "banks": { "description": "TCM bank 数", "default": 2 },
        "software_alias_base": {
          "description": "软件应使用的 TCM 高地址 alias 基地址。高地址 alias 不受 PMA/TLB access fault 影响，比低地址窗口更稳妥",
          "formula": "alias_base(tile_id) = address + nextPowerOf2(num_tiles) * size + size * tile_id",
          "derivation": [
            "replicationSize = nextPowerOf2(num_tiles) * size",
            "AddressOffsetter 将低地址窗口 OR 上 replicationSize 得到高地址 alias",
            "tcmMasterReplicator 减掉低半区后，本地 master 路径仅可见高地址 alias"
          ],
          "examples_default_2MiB": {
            "_note": "默认 address=0x70000000, size=0x200000(2MiB)",
            "1_tile": {
              "replicationSize": "0x200000",
              "tile_0": "0x70200000"
            },
            "2_tiles": {
              "replicationSize": "0x400000",
              "tile_0": "0x70400000",
              "tile_1": "0x70600000"
            },
            "4_tiles": {
              "replicationSize": "0x800000",
              "tile_0": "0x70800000",
              "tile_1": "0x70A00000",
              "tile_2": "0x70C00000",
              "tile_3": "0x70E00000"
            },
            "8_tiles": {
              "replicationSize": "0x1000000",
              "tile_0": "0x71000000",
              "tile_1": "0x71200000",
              "tile_2": "0x71400000",
              "tile_3": "0x71600000",
              "tile_4": "0x71800000",
              "tile_5": "0x71A00000",
              "tile_6": "0x71C00000",
              "tile_7": "0x71E00000"
            }
          }
        }
      }
    }
  },

  "cute_instances": {
    "description": "CUTE 加速器实例化配置。Seq(0) = 1 个 CUTE 实例挂在 core 0 上，Seq(0,1) = 2 个实例。",
    "note": "实例数量必须与核心数量匹配。Shuttle 1 核最多 1 实例，4 核最多 4 实例。",
    "examples": {
      "Seq(0)": "1 个 CUTE，挂在第 0 个核心",
      "Seq(0,1)": "2 个 CUTE，分别挂在第 0、1 核心",
      "Seq(0,1,2,3)": "4 个 CUTE，分别挂在第 0-3 核心"
    }
  },

  "version_refs": {
    "fpe_versions": {
      "description": "FPE datatype 版本。定义支持的 dtype 组合。",
      "ref_dir": "configs/cute_fpe_versions/"
    },
    "isa_versions": {
      "description": "ISA 指令集版本。定义指令编码和 funct。",
      "ref_dir": "configs/cute_isa_versions/"
    },
    "vector_versions": {
      "description": "向量扩展版本。none = 无向量，saturn_rvv = Saturn RVV。",
      "ref_dir": "configs/vector_versions/"
    }
  }
}
