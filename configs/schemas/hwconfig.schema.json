{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CUTE HWConfig",
  "description": "可运行硬件目标组合。HWConfig 引用 ChipyardConfig，并绑定 memory model 与 simulator policy。",
  "type": "object",
  "required": ["version", "name", "chipyard_config", "memory", "simulator"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema 版本，当前固定为 1"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "HWConfig 唯一标识，如 cute2tops_scp64_dramsim32"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "标签列表，供 project.target matcher 使用"
    },
    "chipyard_config": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "引用 configs/chipyard_configs/<id>.yaml"
    },
    "memory": {
      "type": "object",
      "required": ["model"],
      "additionalProperties": false,
      "description": "内存模型配置引用。model=configs/memconfigs/<model>/，config 为其下的配置目录名。",
      "properties": {
        "model": {
          "type": "string",
          "enum": ["dramsim2", "none"],
          "description": "内存模型类型。dramsim2 表示使用 configs/memconfigs/dramsim2/<config>/。"
        },
        "config": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+$",
          "description": "内存模型配置目录名，如 dramsim2_ini_32GB_per_s"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "model": { "const": "dramsim2" } },
            "required": ["model"]
          },
          "then": { "required": ["config"] }
        },
        {
          "if": {
            "properties": { "model": { "const": "none" } },
            "required": ["model"]
          },
          "then": { "not": { "required": ["config"] } }
        }
      ]
    },
    "simulator": {
      "type": "object",
      "required": ["backend", "binary", "max_cycles"],
      "additionalProperties": false,
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["verilator", "vcs", "fpga"],
          "description": "仿真后端"
        },
        "binary": {
          "type": "string",
          "description": "auto: 自动查找; 或指定路径"
        },
        "max_cycles": {
          "type": "integer",
          "minimum": 1,
          "description": "最大仿真周期数"
        }
      }
    }
  }
}
