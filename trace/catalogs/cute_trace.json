{
  "version": 1,
  "catalog_id": "cute_trace_v1",
  "description": "CUTETrace 的种子 catalog。Phase 0.6 从 cute_inst 和 cute_task trace 事件开始，并为 cute_loadstore、cute_compute、vector_loadstore 类别预留扩展位。",
  "categories": [
    {
      "name": "cute_inst",
      "id": 0,
      "description": "发往 CUTE 的指令、完成、程序退出相关观测。"
    },
    {
      "name": "cute_task",
      "id": 1,
      "description": "CUTE 内部 task 的 issue、start、end、commit 生命周期。"
    },
    {
      "name": "cute_loadstore",
      "id": 2,
      "description": "CUTE 内部 load 读取和 store 写回的观测。"
    },
    {
      "name": "cute_compute",
      "id": 3,
      "description": "MTE 计算输入、输出和结果的观测。"
    },
    {
      "name": "vector_loadstore",
      "id": 4,
      "description": "vector 与 CUTE 配合时的访存观测。"
    }
  ],
  "modules": [
    {
      "name": "TaskController",
      "id": 1,
      "description": "CUTE 宏指令/微指令调度与生命周期管理模块。"
    },
    {
      "name": "AML",
      "id": 2,
      "description": "A 张量加载模块。"
    },
    {
      "name": "BML",
      "id": 3,
      "description": "B 张量加载模块。"
    },
    {
      "name": "CML",
      "id": 4,
      "description": "C/D 张量加载与 store 写回模块。"
    },
    {
      "name": "MTE",
      "id": 5,
      "description": "矩阵张量计算引擎。"
    },
    {
      "name": "LocalMMU",
      "id": 6,
      "description": "CUTE 本地 MMU 与内存请求路由模块。"
    }
  ],
  "tasks": [
    {
      "name": "TaskControllerTrace",
      "id": 1,
      "module": "TaskController",
      "method_group": "TaskControllerTrace",
      "description": "TaskController 的宏/微任务生命周期 trace 组。"
    },
    {
      "name": "AMLLoad",
      "id": 2,
      "module": "AML",
      "method_group": "AMLLoad",
      "description": "A 张量加载任务 trace 组。"
    },
    {
      "name": "BMLLoad",
      "id": 3,
      "module": "BML",
      "method_group": "BMLLoad",
      "description": "B 张量加载任务 trace 组。"
    },
    {
      "name": "CMLLoad",
      "id": 4,
      "module": "CML",
      "method_group": "CMLLoad",
      "description": "C 张量加载任务 trace 组。"
    },
    {
      "name": "CMLStore",
      "id": 5,
      "module": "CML",
      "method_group": "CMLStore",
      "description": "D 张量 store 任务 trace 组。"
    },
    {
      "name": "MTECompute",
      "id": 6,
      "module": "MTE",
      "method_group": "MTECompute",
      "description": "MTE 计算任务 trace 组。"
    }
  ],
  "events": [
    {
      "name": "TaskControllerTrace.macroInstInsert",
      "method": "macroInstInsert",
      "id": 1,
      "task": "TaskControllerTrace",
      "category": "cute_inst",
      "description": "向 TaskController 插入一条宏指令。",
      "fields": [
        {
          "name": "macro_id",
          "type": "uint",
          "fmt": "dec"
        },
        {
          "name": "opcode",
          "type": "uint",
          "fmt": "hex"
        }
      ],
      "render": "macro_id={macro_id} opcode=0x{opcode:x}"
    },
    {
      "name": "TaskControllerTrace.macroInstDecodeStart",
      "method": "macroInstDecodeStart",
      "id": 2,
      "task": "TaskControllerTrace",
      "category": "cute_inst",
      "description": "TaskController 开始解码一条宏指令。",
      "fields": [
        {
          "name": "macro_id",
          "type": "uint",
          "fmt": "dec"
        },
        {
          "name": "opcode",
          "type": "uint",
          "fmt": "hex"
