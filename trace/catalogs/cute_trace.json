      "id": 3,
      "task": "TaskControllerTrace",
      "category": "cute_inst",
      "description": "TaskController 完成一条宏指令的解码。",
      "fields": [
        {
          "name": "macro_id",
          "type": "uint",
          "fmt": "dec"
        },
        {
          "name": "load_tasks",
          "type": "uint",
          "fmt": "dec"
        },
        {
          "name": "compute_tasks",
          "type": "uint",
          "fmt": "dec"
        },
        {
          "name": "store_tasks",
          "type": "uint",
          "fmt": "dec"
        }
      ],
      "render": "macro_id={macro_id} load_tasks={load_tasks} compute_tasks={compute_tasks} store_tasks={store_tasks}"
